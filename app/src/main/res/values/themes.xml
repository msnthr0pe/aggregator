<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PracticumAndroidDiploma" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="toolbarStyle">@style/CustomToolbar</item>
        <item name="defaultTextColor">@color/black</item>
        <item name="defaultBackground">@color/white</item>

        <item name="android:windowBackground">?attr/defaultBackground</item>

        <item name="searchBackground">@color/light_gray</item>
        <item name="searchTint">@color/gray</item>
    </style>

    <!-- Стили для Toolbar -->
    <style name="CustomToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:minHeight">@dimen/toolbar_height</item>
        <item name="android:layout_height">@dimen/toolbar_height</item>
        <item name="contentInsetStart">@dimen/spacing_md</item>
        <item name="contentInsetStartWithNavigation">@dimen/spacing_xs</item>
        <item name="titleTextColor">@color/toolbar_color</item>
        <item name="navigationIconTint">@color/toolbar_color</item>
        <item name="android:paddingEnd">@dimen/spacing_xs</item>
    </style>

    <style name="CustomToolbarTitle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Стили для Button -->
    <style name="ButtonPrimary">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="backgroundTint">@color/blue</item>
    </style>

    <style name="ButtonTextError" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/red</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>

    <style name="Theme.PracticumAndroidDiploma" parent="Base.Theme.PracticumAndroidDiploma" />
</resources>

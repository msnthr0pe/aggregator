<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ButtonFind" parent="ButtonPrimary">
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="CustomBottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconSize">24dp</item>
        <item name="itemIconTint">@color/bottom_navigation_colors</item>
        <item name="itemTextColor">@color/bottom_navigation_colors</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.CustomBottomNav.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.CustomBottomNav.Inactive</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="TextAppearance.CustomBottomNav.Active" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">@dimen/text_size_xs</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="TextAppearance.CustomBottomNav.Inactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">@dimen/text_size_xs</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="VacancyItemImg">
        <item name="android:scaleType">center</item>
        <item name="cornerSize">@dimen/radius_md</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/light_gray</item>
    </style>

    <style name="VacancyItemImgOverlay">
        <item name="cornerSize">@dimen/radius_md</item>
    </style>

    <style name="VacancyItemTitle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="VacancyItemText">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="FavoritesPlaceholder">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="TitleText">
        <item name="android:fontFamily">@font/ys_display_bold</item>
        <item name="android:textSize">@dimen/text_size_xxl</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="SubtitleText">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="SmallTitleText">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="SmallText">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textColor">@color/black</item>
    </style>
</resources>



<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".settingsfilter.ui.FiltersFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        app:title="@string/filter_settings"
        app:titleTextAppearance="@style/ToolbarTitleAppearance"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:navigationIcon="@drawable/arrow_left" />

    <FrameLayout
        android:id="@+id/empty_industry_button"
        style="@style/SearchLayout"
        android:paddingVertical="0dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginHorizontal="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/empty_industry_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/industry"
            android:layout_marginVertical="@dimen/spacing_md"
            style="@style/SmallText" />

        <ImageView
            android:id="@+id/empty_industry_icon"
            android:layout_width="@dimen/default_icon"
            android:layout_height="@dimen/default_icon"
            android:layout_gravity="end|center_vertical"
            android:src="@drawable/arrow_forward"/>

        <TextView
            android:id="@+id/filled_industry_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/industry"
            android:textColor="@color/black"
            android:visibility="gone"
            style="@style/SmallHintText" />

        <TextView
            android:id="@+id/filled_industry_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/spacing_sm"
            android:visibility="gone"
            style="@style/SmallText" />

        <ImageView
            android:id="@+id/filled_industry_icon_cross"
            android:layout_width="@dimen/default_icon"
            android:layout_height="@dimen/default_icon"
            android:layout_gravity="end|center_vertical"
            android:visibility="gone"
            android:src="@drawable/cross"/>

    </FrameLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/desired_salary_wrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:layout_marginHorizontal="@dimen/spacing_md"
        app:layout_constraintTop_toBottomOf="@id/empty_industry_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:hintEnabled="false"
        app:endIconMode="clear_text"
        app:endIconDrawable="@drawable/cross"
        style="@style/SearchLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/desired_salary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_height"
            android:inputType="number"
            android:hint="@string/enter_sum"
            style="@style/SearchEditText" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/salary_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/expected_salary"
        android:layout_marginTop="@dimen/spacing_12"
        android:layout_marginStart="@dimen/spacing_md"
        style="@style/SmallHintText"
        app:layout_constraintStart_toStartOf="@+id/desired_salary_wrapper"
        app:layout_constraintTop_toTopOf="@+id/desired_salary_wrapper" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/desired_salary_wrapper">

        <TextView
            android:id="@+id/label"
            style="@style/SmallText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/do_not_show_without_salary" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:buttonTint="@color/checkbox_tint" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_confirm_discard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/confirm_discard_layout_height"
        android:layout_margin="@dimen/spacing_md"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/big_button_height"
            style="@style/BigButton"
            android:text="@string/apply"/>

        <TextView
            android:id="@+id/discard_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/big_button_height"
            style="@style/BigButton"
            android:textColor="@color/red"
            android:gravity="center"
            android:backgroundTint="@android:color/transparent"
            android:layout_gravity="bottom"
            android:text="@string/discard"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
